PORT=8080
EXTRACTOR_TOKEN=mgresv-extractor-secret-123
MAX_FETCH_MS=25000

# Provider strategy: auto | apify | rapidapi | lite
PROVIDER_MODE=auto

# Apify provider, recommended for stable public post scraping
APIFY_TOKEN=
APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
APIFY_INSTAGRAM_ACTOR=apify/instagram-post-scraper
APIFY_TIMEOUT_SECS=45

# RapidAPI provider for TikTok slide/video APIs
RAPIDAPI_KEY=
RAPIDAPI_TIKTOK_HOST=download-tiktok-videos-slide-images.p.rapidapi.com
RAPIDAPI_TIKTOK_ENDPOINT=
RAPIDAPI_INSTAGRAM_HOST=
RAPIDAPI_INSTAGRAM_ENDPOINT=

# Optional Facebook Apify actor for public post/photo extraction
APIFY_FACEBOOK_ACTOR=


# Optional Apify actors for more platforms
APIFY_X_ACTOR=apidojo/tweet-scraper
APIFY_THREADS_ACTOR=automation-lab/threads-scraper
APIFY_PINTEREST_ACTOR=danielmilevski9/pinterest-crawler
APIFY_REDDIT_ACTOR=trudax/reddit-scraper
APIFY_VIMEO_ACTOR=
APIFY_SOUNDCLOUD_ACTOR=
